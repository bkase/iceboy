{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iceboy.local/bench/schemas/oracle_capture.schema.json",
  "title": "OracleCapture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rom_id",
    "oracle_mode",
    "oracle_backend",
    "capture"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "rom_id": { "type": "string", "minLength": 1 },
    "oracle_mode": {
      "enum": [
        "unit",
        "instr_commit",
        "mcycle_commit",
        "checkpoint",
        "frame_semantic",
        "frame_hash"
      ]
    },
    "oracle_backend": { "type": "string", "minLength": 1 },
    "capture": { "type": "object" },
    "metadata": {
      "type": "object",
      "default": {}
    }
  }
}
