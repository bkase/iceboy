MACRO ICEBOY_PPU_SCENE_INIT
    di
    ld sp, $FFFE
    call InitAbiSignature
    xor a
    ld [rIF], a
    ld [rIE], a
    ld [rLCDC], a
    ld [rSCY], a
    ld [rSCX], a
    ld [rLYC], a
    ld [rWY], a
    ld [rWX], a
ENDM

MACRO ICEBOY_PPU_SCENE_PASS
    ld a, \1
    ld [wPassCountLo], a
    ICEBOY_LOG_CASE \2, $00, ABI_LOG_STATUS_PASS, \3, \4, \5
    ICEBOY_SET_RESULT ABI_RESULT_PASS
    jp __pass
ENDM
