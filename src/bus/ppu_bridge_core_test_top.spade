use lib::bus::ppu_event_bridge::ppu_event_bridge;
use lib::bus::types::BusReq;
use lib::ppu::rtl::core::ppu_core;
use lib::ppu::sem::events::{VideoCoord, idle_oam_dma_state};
use lib::ppu::sem::memory::idle_ppu_mem_resp;
use lib::ppu::sem::types::{LcdRunState, PpuMode, PpuPhase};

fn encode_phase(phase: PpuPhase) -> uint<3> {
    match phase {
        PpuPhase::LcdOff => 0u3,
        PpuPhase::OamScan$(index: _, found: _) => 1u3,
        PpuPhase::Transfer$(x_out: _, discard_scx: _) => 2u3,
        PpuPhase::HBlank$(dots_left: _) => 3u3,
        PpuPhase::VBlank$(line: _, dots_left: _) => 4u3,
    }
}

fn encode_mode(mode: PpuMode) -> uint<3> {
    match mode {
        PpuMode::LcdOff => 0u3,
        PpuMode::OamScan => 1u3,
        PpuMode::PixelTransfer => 2u3,
        PpuMode::HBlank => 3u3,
        PpuMode::VBlank => 4u3,
    }
}

fn encode_run(run: LcdRunState) -> uint<2> {
    match run {
        LcdRunState::Disabled => 0u2,
        LcdRunState::WarmupBlankFrame => 1u2,
        LcdRunState::Running => 2u2,
    }
}

pub entity ppu_bridge_core_test_top(
    clk_i: clock,
    rst_i: bool,
    dot_ce_i: bool,
    m_ce_i: bool,
    req_kind_i: uint<2>,
    addr_i: uint<16>,
    data_i: uint<8>,
    frame_start_i: bool,
    line_index_i: uint<8>,
    dot_in_line_i: uint<9>,
) -> uint<45> {
    let req = match req_kind_i {
        1u2 => BusReq::Read$(addr: addr_i),
        2u2 => BusReq::Write$(addr: addr_i, data: data_i),
        _ => BusReq::Idle,
    };
    let (bus_events, bus_event_count) = inst ppu_event_bridge(
        clk_i,
        rst_i,
        m_ce_i,
        req,
        frame_start_i,
        line_index_i,
        dot_in_line_i,
    );
    let core = inst ppu_core(
        clk_i,
        rst_i,
        dot_ce_i,
        VideoCoord$(frame: 0u32, line: line_index_i, dot: dot_in_line_i),
        bus_events,
        bus_event_count,
        idle_ppu_mem_resp(),
        idle_oam_dma_state(),
    );
    let trace = core.visible_trace;

    zext(encode_phase(trace.phase_after))
        | (zext(trace.ly_after) << 3)
        | (zext(trace.dot_in_line_after) << 11)
        | (zext(encode_mode(trace.mode_after)) << 20)
        | (zext(if trace.stat_line_after { 1u1 } else { 0u1 }) << 23)
        | (zext(if core.irq_req.vblank_req { 1u1 } else { 0u1 }) << 24)
        | (zext(if core.irq_req.stat_req { 1u1 } else { 0u1 }) << 25)
        | (zext(encode_run(trace.run_after)) << 26)
        | (zext(if trace.first_frame_blank_after { 1u1 } else { 0u1 }) << 28)
        | (zext(trace.stat_readback_after) << 29)
        | (zext(bus_event_count) << 37)
        | (zext(if m_ce_i { 1u1 } else { 0u1 }) << 41)
        | (zext(if dot_ce_i { 1u1 } else { 0u1 }) << 42)
        | (zext(if frame_start_i { 1u1 } else { 0u1 }) << 43)
        | (zext(req_kind_i) << 44)
}
