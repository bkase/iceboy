use lib::bus::ppu_event_bridge::ppu_event_bridge;
use lib::bus::types::BusReq;
use lib::ppu::rtl::core::ppu_core;
use lib::ppu::sem::events::{VideoCoord, idle_oam_dma_state};
use lib::ppu::sem::memory::idle_ppu_mem_resp;
use lib::sim::ppu_support::{encode_lcd_run, encode_ppu_mode, encode_ppu_phase};

pub entity ppu_bridge_core_test_top(
    clk_i: clock,
    rst_i: bool,
    dot_ce_i: bool,
    m_ce_i: bool,
    req_kind_i: uint<2>,
    addr_i: uint<16>,
    data_i: uint<8>,
    frame_start_i: bool,
    line_index_i: uint<8>,
    dot_in_line_i: uint<9>,
) -> uint<45> {
    let req = match req_kind_i {
        1u2 => BusReq::Read$(addr: addr_i),
        2u2 => BusReq::Write$(addr: addr_i, data: data_i),
        _ => BusReq::Idle,
    };
    let (bus_events, bus_event_count) = inst ppu_event_bridge(
        clk_i,
        rst_i,
        m_ce_i,
        req,
        frame_start_i,
        line_index_i,
        dot_in_line_i,
    );
    let core = inst ppu_core(
        clk_i,
        rst_i,
        dot_ce_i,
        VideoCoord$(frame: 0u32, line: line_index_i, dot: dot_in_line_i),
        bus_events,
        bus_event_count,
        idle_ppu_mem_resp(),
        idle_oam_dma_state(),
    );
    let trace = core.visible_trace;

    zext(encode_ppu_phase(trace.phase_after))
        | (zext(trace.ly_after) << 3)
        | (zext(trace.dot_in_line_after) << 11)
        | (zext(encode_ppu_mode(trace.mode_after)) << 20)
        | (zext(lib::util::bit(trace.stat_line_after)) << 23)
        | (zext(lib::util::bit(core.irq_req.vblank_req)) << 24)
        | (zext(lib::util::bit(core.irq_req.stat_req)) << 25)
        | (zext(encode_lcd_run(trace.run_after)) << 26)
        | (zext(lib::util::bit(trace.first_frame_blank_after)) << 28)
        | (zext(trace.stat_readback_after) << 29)
        | (zext(bus_event_count) << 37)
        | (zext(lib::util::bit(m_ce_i)) << 41)
        | (zext(lib::util::bit(dot_ce_i)) << 42)
        | (zext(lib::util::bit(frame_start_i)) << 43)
        | (zext(req_kind_i) << 44)
}
