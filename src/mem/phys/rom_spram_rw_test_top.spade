use lib::mem::phys::rom_backend_types::RomBackendPorts;
use lib::mem::phys::rom_spram_rw::rom_spram_rw;

pub entity rom_spram_rw_test_top(
    clk_i: clock,
    t_index_i: uint<2>,
    cpu_addr_i: uint<15>,
    dma_addr_i: uint<15>,
    loader_write_en_i: bool,
    loader_write_addr_i: uint<15>,
    loader_write_data_i: uint<8>,
) -> uint<17> {
    let backend = inst rom_spram_rw(
        clk_i,
        t_index_i,
        RomBackendPorts$(
            cpu_addr: cpu_addr_i,
            dma_addr: dma_addr_i,
            loader_write_en: loader_write_en_i,
            loader_write_addr: loader_write_addr_i,
            loader_write_data: loader_write_data_i,
        ),
    );

    let cpu_bits: uint<17> = zext(backend.cpu_data) << 9;
    let dma_bits: uint<17> = zext(backend.dma_data) << 1;
    let ready_bits: uint<17> = zext(lib::util::bit(backend.rom_ready));

    cpu_bits | dma_bits | ready_bits
}
