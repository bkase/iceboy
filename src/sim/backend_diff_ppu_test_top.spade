use lib::ppu::sem::events::{idle_oam_dma_state, zero_video_coord};
use lib::ppu::sem::events::mmio::{MmioReg, MmioWrite};
use lib::ppu::sem::memory::{MemClient, MemRegion, PpuMemKind, PpuMemReq, PpuMemResp, PpuMemResult, idle_ppu_mem_req, idle_ppu_mem_resp};
use lib::ppu::sem::observe::PpuIrqEdge;
use lib::ppu::sem::scanout::ScanoutEvent;
use lib::ppu::sem::stimulus::{RasterStimulus, idle_raster_stimulus, single_reg_write_stimulus};
use lib::sim::encode::{encode_scanout_kind, scanout_y};
use lib::sim::ppu_support::encode_ppu_mode;
use lib::sim::ppu_test_top::ppu_test_top;

fn encode_irq_edge(edge: PpuIrqEdge) -> uint<2> {
    match edge {
        PpuIrqEdge::None => 0u2,
        PpuIrqEdge::VBlank => 1u2,
        PpuIrqEdge::Stat => 2u2,
        PpuIrqEdge::Both => 3u2,
    }
}

fn encode_mem_region(region: MemRegion) -> uint<1> {
    match region {
        MemRegion::Vram => 0u1,
        MemRegion::Oam => 1u1,
    }
}

fn encode_mem_client(client: MemClient) -> uint<3> {
    match client {
        MemClient::Cpu => 0u3,
        MemClient::BgFetcher => 1u3,
        MemClient::ObjFetcher => 2u3,
        MemClient::OamScanner => 3u3,
        MemClient::Dma => 4u3,
    }
}

fn response_data(req: PpuMemReq) -> uint<8> {
    match req.tag.region {
        MemRegion::Oam => trunc((req.addr & 0x00ffu16) ^ 0x0033u16),
        MemRegion::Vram => trunc((req.addr & 0x00ffu16) ^ 0x005au16),
    }
}

fn ok_mem_resp(req: PpuMemReq) -> PpuMemResp {
    let result = match req.kind {
        PpuMemKind::Read => PpuMemResult::Ok$(data: response_data(req)),
        PpuMemKind::Write$(data: data) => PpuMemResult::Ok$(data: data),
    };
    PpuMemResp$(tag: req.tag, result: result)
}

fn scanout_valid(scanout: ScanoutEvent) -> bool {
    match scanout {
        ScanoutEvent::Blank$(y: _, reason: _) => true,
        ScanoutEvent::FrameStart => true,
        ScanoutEvent::LineStart$(y: _) => true,
        ScanoutEvent::Pixel$(emit: _) => true,
    }
}

fn enable_lcdc_stimulus(enable_sent: bool) -> RasterStimulus {
    if !enable_sent {
        single_reg_write_stimulus(MmioWrite$(target: MmioReg::Lcdc, value: 0x91u8))
    } else {
        idle_raster_stimulus()
    }
}

pub entity backend_diff_ppu_test_top(
    clk_i: clock,
    rst_i: bool,
    dot_ce_i: bool,
) -> uint<53> {
    decl pending_req_reg;
    decl pending_resp_valid_reg;
    decl enable_sent_reg;
    let mem_resp_now = if pending_resp_valid_reg { ok_mem_resp(pending_req_reg) } else { idle_ppu_mem_resp() };
    let top = inst ppu_test_top(
        clk_i,
        rst_i,
        dot_ce_i,
        zero_video_coord(),
        enable_lcdc_stimulus(enable_sent_reg),
        mem_resp_now,
        idle_oam_dma_state(),
    );
    let next_pending_req = if top.mem_reqs.count != 0u3 { top.mem_reqs.slots[0] } else { idle_ppu_mem_req() };

    reg(clk_i) pending_req_reg: PpuMemReq reset(rst_i: idle_ppu_mem_req()) =
        if dot_ce_i { next_pending_req } else { pending_req_reg };
    reg(clk_i) pending_resp_valid_reg: bool reset(rst_i: false) =
        if dot_ce_i { top.mem_reqs.count != 0u3 } else { pending_resp_valid_reg };
    reg(clk_i) enable_sent_reg: bool reset(rst_i: false) =
        if dot_ce_i { true } else { enable_sent_reg };

    zext(top.semantic.ly_after)
        | (zext(encode_ppu_mode(top.semantic.mode_after)) << 8)
        | (zext(lib::util::bit(top.semantic.stat_line_after)) << 11)
        | (zext(encode_irq_edge(top.semantic.irq_edge)) << 12)
        | (zext(lib::util::bit(scanout_valid(top.scanout))) << 14)
        | (zext(encode_scanout_kind(top.scanout)) << 15)
        | (zext(scanout_y(top.scanout)) << 17)
        | (zext(top.mem_reqs.count) << 25)
        | (zext(next_pending_req.addr) << 28)
        | (zext(encode_mem_region(next_pending_req.tag.region)) << 44)
        | (zext(encode_mem_client(next_pending_req.tag.client)) << 45)
        | (zext(next_pending_req.tag.id) << 48)
        | (zext(lib::util::bit(top.semantic_valid)) << 52)
}
