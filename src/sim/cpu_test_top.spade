use lib::sim::types::{SimStimulus, cpu_arch_time_enable};

struct CpuTestTopOut {
    bus_read_data: uint<8>,
    irq_pending: uint<5>,
    cpu_arch_time_enable: bool,
    freeze_arch_time: bool,
    cpu_hold_only: bool,
}

entity cpu_test_top(
    clk: clock,
    rst: bool,
    stimulus: SimStimulus,
    bus_read_data: uint<8>,
    irq_pending: uint<5>,
) -> CpuTestTopOut {
    let _ = (clk, rst);
    CpuTestTopOut$(
        bus_read_data: bus_read_data,
        irq_pending: irq_pending,
        cpu_arch_time_enable: cpu_arch_time_enable(stimulus),
        freeze_arch_time: stimulus.freeze_arch_time,
        cpu_hold_only: stimulus.cpu_hold_only,
    )
}
