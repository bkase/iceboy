use lib::cpu::alu::AluReq;

pub struct ArithmeticAluOut {
    val8: uint<8>,
    z: bool,
    n: bool,
    h: bool,
    c: bool,
}

fn selected_req(op: uint<3>, a: uint<8>, b: uint<8>, carry_in: bool) -> AluReq {
    match op {
        0u3 => AluReq::Add8$(a: a, b: b, carry_in: false),
        1u3 => AluReq::Add8$(a: a, b: b, carry_in: carry_in),
        2u3 => AluReq::Sub8$(a: a, b: b, carry_in: false),
        3u3 => AluReq::Sub8$(a: a, b: b, carry_in: carry_in),
        4u3 => AluReq::Cp8$(a: a, b: b),
        _ => AluReq::Idle,
    }
}

pub entity arithmetic_alu_test_top(op: uint<3>, a: uint<8>, b: uint<8>, carry_in: bool) -> ArithmeticAluOut {
    let result = lib::cpu::alu::alu(selected_req(op, a, b, carry_in));

    ArithmeticAluOut$(
        val8: result.val8,
        z: result.flags.z,
        n: result.flags.n,
        h: result.flags.h,
        c: result.flags.c,
    )
}
