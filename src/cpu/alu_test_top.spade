use lib::cpu::alu::AluReq;
use lib::cpu::regs::Flags;

pub struct ArithmeticAluOut {
    val8: uint<8>,
    z: bool,
    n: bool,
    h: bool,
    c: bool,
}

fn selected_req(op: uint<4>, a: uint<8>, b: uint<8>, carry_in: bool) -> AluReq {
    match op {
        0u4 => AluReq::Add8$(a: a, b: b, carry_in: false),
        1u4 => AluReq::Add8$(a: a, b: b, carry_in: carry_in),
        2u4 => AluReq::Sub8$(a: a, b: b, carry_in: false),
        3u4 => AluReq::Sub8$(a: a, b: b, carry_in: carry_in),
        4u4 => AluReq::Cp8$(a: a, b: b),
        5u4 => AluReq::And8$(a: a, b: b),
        6u4 => AluReq::Or8$(a: a, b: b),
        7u4 => AluReq::Xor8$(a: a, b: b),
        8u4 => AluReq::Inc8$(x: a, f_prev: Flags$(z: false, n: false, h: false, c: carry_in)),
        9u4 => AluReq::Dec8$(x: a, f_prev: Flags$(z: false, n: false, h: false, c: carry_in)),
        _ => AluReq::Idle,
    }
}

pub entity arithmetic_alu_test_top(op: uint<4>, a: uint<8>, b: uint<8>, carry_in: bool) -> ArithmeticAluOut {
    let result = lib::cpu::alu::alu(selected_req(op, a, b, carry_in));

    ArithmeticAluOut$(
        val8: result.val8,
        z: result.flags.z,
        n: result.flags.n,
        h: result.flags.h,
        c: result.flags.c,
    )
}
