pub fn decode_cb(opcode: uint<8>) -> DecodedOp {
    let group: uint<2> = trunc(opcode >> 6);
    let y: uint<3> = trunc(opcode >> 3);
    let z: uint<3> = trunc(opcode);
    let target = operand8_from_reg_code(z);
    let addressing = addressing_for_r8_target(z);
    let prefix = some_prefix(PrefixKind::Cb);

    match group {
        0u2 => {
            let kind = match y {
                0u3 => RotShiftKind::Rlc,
                1u3 => RotShiftKind::Rrc,
                2u3 => RotShiftKind::Rl,
                3u3 => RotShiftKind::Rr,
                4u3 => RotShiftKind::Sla,
                5u3 => RotShiftKind::Sra,
                6u3 => RotShiftKind::Swap,
                _ => RotShiftKind::Srl,
            };

            bit_op(BitOpKind::RotateShift$(kind: kind), prefix, target, Option::None, true, addressing)
        },
        1u2 => bit_op(BitOpKind::Bit, prefix, target, some_bit_index(y), false, addressing),
        2u2 => bit_op(BitOpKind::Res, prefix, target, some_bit_index(y), false, addressing),
        _ => bit_op(BitOpKind::Set, prefix, target, some_bit_index(y), false, addressing),
    }
}
