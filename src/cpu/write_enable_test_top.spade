use lib::bus::types::{BusReq, BusResp};
use lib::cpu::decode::decode;
use lib::cpu::regs::{R8, Registers};
use lib::cpu::semantics::{apply_delta, step_mcycle};
use lib::cpu::types::{
    CpuArchState,
    CpuMicroState,
    CpuState,
    HaltState,
    ImeState,
    Imm8Cont,
    IrqPending,
    MicroInput,
    Phase,
    ReadCont,
    WriteCont,
};

fn r8_from_code(code: uint<3>) -> R8 {
    match code {
        0u3 => R8::B,
        1u3 => R8::C,
        2u3 => R8::D,
        3u3 => R8::E,
        4u3 => R8::H,
        5u3 => R8::L,
        _ => R8::A,
    }
}

fn ime_from_code(code: uint<2>) -> ImeState {
    match code {
        1u2 => ImeState::PendingEnable,
        2u2 => ImeState::Enabled,
        _ => ImeState::Disabled,
    }
}

fn ime_code(ime: ImeState) -> uint<2> {
    match ime {
        ImeState::Disabled => 0u2,
        ImeState::PendingEnable => 1u2,
        ImeState::Enabled => 2u2,
    }
}

fn phase_from_inputs(
    kind: uint<4>,
    addr: uint<16>,
    data: uint<8>,
    cont_data: uint<8>,
    decoded: lib::cpu::decode_types::DecodedOp,
) -> Phase {
    match kind {
        2u4 => Phase::Execute$(op: decoded),
        3u4 => Phase::ReadImm8$(k: Imm8Cont::LoadReg8$(dst: r8_from_code(trunc(cont_data)))),
        6u4 => Phase::ReadMem$(addr: addr, k: ReadCont::LoadReg8$(dst: r8_from_code(trunc(cont_data)))),
        7u4 => Phase::WriteMem$(addr: addr, data: data, k: WriteCont::StoreDone),
        _ => Phase::Fetch,
    }
}

fn phase_projection(phase: Phase) -> (uint<4>, uint<16>, uint<8>, uint<8>) {
    match phase {
        Phase::Fetch => (0u4, 0u16, 0u8, 0u8),
        Phase::Execute$(op) => { let _ = op; (2u4, 0u16, 0u8, 0u8) },
        Phase::ReadImm8$(k) => {
            match k {
                Imm8Cont::LoadReg8$(dst) => {
                    match dst {
                        R8::B => (3u4, 0u16, 0u8, 0u8),
                        R8::C => (3u4, 0u16, 0u8, 1u8),
                        R8::D => (3u4, 0u16, 0u8, 2u8),
                        R8::E => (3u4, 0u16, 0u8, 3u8),
                        R8::H => (3u4, 0u16, 0u8, 4u8),
                        R8::L => (3u4, 0u16, 0u8, 5u8),
                        R8::A => (3u4, 0u16, 0u8, 7u8),
                    }
                },
                _ => (15u4, 0u16, 0u8, 0u8),
            }
        },
        Phase::ReadMem$(addr, k) => {
            match k {
                ReadCont::LoadReg8$(dst) => {
                    match dst {
                        R8::B => (6u4, addr, 0u8, 0u8),
                        R8::C => (6u4, addr, 0u8, 1u8),
                        R8::D => (6u4, addr, 0u8, 2u8),
                        R8::E => (6u4, addr, 0u8, 3u8),
                        R8::H => (6u4, addr, 0u8, 4u8),
                        R8::L => (6u4, addr, 0u8, 5u8),
                        R8::A => (6u4, addr, 0u8, 7u8),
                    }
                },
                _ => (15u4, 0u16, 0u8, 0u8),
            }
        },
        Phase::WriteMem$(addr, data, k) => {
            let _ = k;
            (7u4, addr, data, 0u8)
        },
        _ => (15u4, 0u16, 0u8, 0u8),
    }
}

fn bus_req_kind(req: BusReq) -> uint<2> {
    match req {
        BusReq::Idle => 0u2,
        BusReq::Read$(addr: _) => 1u2,
        BusReq::Write$(addr: _, data: _) => 2u2,
    }
}

fn bus_req_addr(req: BusReq) -> uint<16> {
    match req {
        BusReq::Idle => 0u16,
        BusReq::Read$(addr: addr) => addr,
        BusReq::Write$(addr: addr, data: _) => addr,
    }
}

fn bus_req_data(req: BusReq) -> uint<8> {
    match req {
        BusReq::Idle => 0u8,
        BusReq::Read$(addr: _) => 0u8,
        BusReq::Write$(addr: _, data: data) => data,
    }
}

fn valid_u8(value: std::option::Option<uint<8>>) -> bool {
    match value {
        std::option::Option::Some(v) => { let _ = v; true },
        std::option::Option::None => false,
    }
}

fn valid_u16(value: std::option::Option<uint<16>>) -> bool {
    match value {
        std::option::Option::Some(v) => { let _ = v; true },
        std::option::Option::None => false,
    }
}

fn valid_phase(value: std::option::Option<Phase>) -> bool {
    match value {
        std::option::Option::Some(v) => { let _ = v; true },
        std::option::Option::None => false,
    }
}

entity write_enable_test_top(
    state_pc_i: uint<16>,
    state_sp_i: uint<16>,
    state_a_i: uint<8>,
    state_f_i: uint<8>,
    state_b_i: uint<8>,
    state_c_i: uint<8>,
    state_d_i: uint<8>,
    state_e_i: uint<8>,
    state_h_i: uint<8>,
    state_l_i: uint<8>,
    state_ime_i: uint<2>,
    state_opcode_i: uint<8>,
    state_phase_kind_i: uint<4>,
    state_phase_addr_i: uint<16>,
    state_phase_data_i: uint<8>,
    state_phase_cont_data_i: uint<8>,
    bus_resp_i: uint<8>,
    irq_pending_i: uint<5>,
) -> uint<217> {
    let regs = Registers(
        state_a_i,
        state_f_i,
        state_b_i,
        state_c_i,
        state_d_i,
        state_e_i,
        state_h_i,
        state_l_i,
        state_sp_i,
        state_pc_i,
    );
    let decoded = decode(state_opcode_i);
    let phase = phase_from_inputs(
        state_phase_kind_i,
        state_phase_addr_i,
        state_phase_data_i,
        state_phase_cont_data_i,
        decoded,
    );
    let state = CpuState(
        CpuArchState(regs, ime_from_code(state_ime_i), HaltState::Running),
        CpuMicroState(phase, state_opcode_i, 0u8, 0u8, decoded, 0u16),
    );
    let step = step_mcycle(state, MicroInput(BusResp$(data: bus_resp_i), IrqPending$(pending: irq_pending_i)));
    let next_state = apply_delta(state, step.delta);
    let (next_phase_kind, next_phase_addr, next_phase_data, next_phase_cont_data) = phase_projection(next_state.micro.phase);
    let commit_present = match step.commit {
        std::option::Option::Some(value) => { let _ = value; true },
        std::option::Option::None => false,
    };

    (zext(next_state.arch.regs.pc) << 201)
    | (zext(next_state.arch.regs.sp) << 185)
    | (zext(next_state.arch.regs.a) << 177)
    | (zext(next_state.arch.regs.f) << 169)
    | (zext(next_state.arch.regs.b) << 161)
    | (zext(next_state.arch.regs.c) << 153)
    | (zext(next_state.arch.regs.d) << 145)
    | (zext(next_state.arch.regs.e) << 137)
    | (zext(next_state.arch.regs.h) << 129)
    | (zext(next_state.arch.regs.l) << 121)
    | (zext(ime_code(next_state.arch.ime_state)) << 119)
    | (zext(next_state.micro.opcode_latch) << 111)
    | (zext(next_phase_kind) << 107)
    | (zext(next_phase_addr) << 91)
    | (zext(next_phase_data) << 83)
    | (zext(next_phase_cont_data) << 75)
    | (zext(bus_req_kind(step.bus_req)) << 73)
    | (zext(bus_req_addr(step.bus_req)) << 57)
    | (zext(bus_req_data(step.bus_req)) << 49)
    | ((if commit_present { 1u217 } else { 0u217 }) << 48)
    | ((if valid_u16(step.delta.pc_write) { 1u217 } else { 0u217 }) << 47)
    | ((if valid_u16(step.delta.sp_write) { 1u217 } else { 0u217 }) << 46)
    | ((if valid_phase(step.delta.micro_write.phase) { 1u217 } else { 0u217 }) << 45)
    | ((if valid_u8(step.delta.regs_write.a) { 1u217 } else { 0u217 }) << 44)
    | ((if valid_u8(step.delta.regs_write.f) { 1u217 } else { 0u217 }) << 43)
    | ((if valid_u8(step.delta.regs_write.b) { 1u217 } else { 0u217 }) << 42)
    | ((if valid_u8(step.delta.regs_write.c) { 1u217 } else { 0u217 }) << 41)
    | ((if valid_u8(step.delta.regs_write.d) { 1u217 } else { 0u217 }) << 40)
    | ((if valid_u8(step.delta.regs_write.e) { 1u217 } else { 0u217 }) << 39)
    | ((if valid_u8(step.delta.regs_write.h) { 1u217 } else { 0u217 }) << 38)
    | ((if valid_u8(step.delta.regs_write.l) { 1u217 } else { 0u217 }) << 37)
}
