use lib::periph::joypad::{decode_buttons, joypad};

pub entity joypad_test_top(
    clk_i: clock,
    rst_i: bool,
    write_en_i: bool,
    write_addr_i: uint<16>,
    write_data_i: uint<8>,
    buttons_i: uint<8>,
) -> uint<9> {
    let joypad_out = inst joypad(
        clk_i,
        rst_i,
        write_en_i,
        write_addr_i,
        write_data_i,
        decode_buttons(buttons_i),
    );

    (zext(joypad_out.p1) << 1) | zext(lib::util::bit(joypad_out.joypad_irq))
}
