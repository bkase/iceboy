fn is_stat_write(write: MmioWrite) -> bool {
    match write.target {
        MmioReg::Stat => true,
        _ => false,
    }
}

fn apply_event(regs: PpuRegs, event: TimedPpuEvent) -> (PpuRegs, bool, bool, bool) {
    match event.kind {
        PpuEventKind::MmioWrite$(write) => (apply_mmio_write(regs, write), is_stat_write(write), false, false),
        PpuEventKind::DmaStart$(source_high: _) => (regs, false, false, false),
        PpuEventKind::ForceLcdPower$(enabled) =>
            if enabled {
                (regs, false, true, false)
            } else {
                (regs, false, false, true)
            },
    }
}

fn fold_events(input: DotInput, regs: PpuRegs) -> (PpuRegs, bool, bool, bool) {
    let (regs0, stat0, enable0, disable0) =
        if input.bus_event_count > 0u4 { apply_event(regs, input.bus_events[0]) } else { (regs, false, false, false) };
    let (regs1, stat1, enable1, disable1) =
        if input.bus_event_count > 1u4 { apply_event(regs0, input.bus_events[1]) } else { (regs0, false, false, false) };
    let (regs2, stat2, enable2, disable2) =
        if input.bus_event_count > 2u4 { apply_event(regs1, input.bus_events[2]) } else { (regs1, false, false, false) };
    let (regs3, stat3, enable3, disable3) =
        if input.bus_event_count > 3u4 { apply_event(regs2, input.bus_events[3]) } else { (regs2, false, false, false) };

    (
        regs3,
        stat0 || stat1 || stat2 || stat3,
        enable0 || enable1 || enable2 || enable3,
        disable0 || disable1 || disable2 || disable3,
    )
}

fn next_dot_in_line(run: LcdRunState, dot_in_line: uint<9>) -> uint<9> {
    match run {
        LcdRunState::Disabled => 0u9,
        _ =>
            if dot_in_line == 455u9 { 0u9 } else { trunc(dot_in_line + 1u9) },
    }
}

fn next_first_frame_blank(run: LcdRunState) -> bool {
    match run {
        LcdRunState::WarmupBlankFrame => true,
        _ => false,
    }
}

fn live_oam_scan_req(scan: OamScanState) -> PpuMemReqs {
    if scan.index >= 40u6 {
        idle_ppu_mem_reqs()
    } else {
        let step = step_oam_scan_entry(
            scan,
            lib::ppu::sem::types::empty_line_obj_list(),
            0u8,
            lib::ppu::sem::types::zero_lcdc(),
            0u8,
            0u8,
        );
        PpuMemReqs$(count: 2u3, slots: [step.req_y, step.req_x, idle_ppu_mem_req(), idle_ppu_mem_req()])
    }
}

fn oam_pair_advance_dot(dot_in_line: uint<9>) -> bool {
    (dot_in_line & 1u9) == 1u9
}

fn advance_live_oam_scan(render: PpuRenderState, status_phase: PpuPhase, visible_ly: uint<8>, regs: PpuRegs) -> (OamScanState, LineObjList) {
    match status_phase {
        PpuPhase::OamScan$(index: _, found: _) =>
            if oam_pair_advance_dot(render.dot_in_line) {
                let step = step_oam_scan_entry(render.oam_scan, render.line_objs, visible_ly, regs.lcdc, 0u8, 0u8);
                (step.next_scan, step.next_list)
            } else {
                (render.oam_scan, render.line_objs)
            },
        _ => (render.oam_scan, render.line_objs),
    }
}

fn update_render_state(
    render: PpuRenderState,
    status_phase: PpuPhase,
    visible_ly: uint<8>,
    regs: PpuRegs,
    next_run: LcdRunState,
    next_phase: PpuPhase,
    line_start: bool,
) -> PpuRenderState {
    let (next_scan, next_list) =
        if line_start {
            (lib::ppu::sem::types::empty_oam_scan_state(), lib::ppu::sem::types::empty_line_obj_list())
        } else {
            advance_live_oam_scan(render, status_phase, visible_ly, regs)
        };
    let next_dot =
        if line_start {
            0u9
        } else {
            next_dot_in_line(next_run, render.dot_in_line)
        };
    let next_x_out = match next_phase {
        PpuPhase::Transfer$(x_out, discard_scx: _) => x_out,
        _ => 0u8,
    };
    PpuRenderState$(
        dot_in_line: next_dot,
        x_out: next_x_out,
        window_state: render.window_state,
        window_line: render.window_line,
        oam_scan: next_scan,
        line_objs: next_list,
        line_obj_fetch_index: if line_start { 0u4 } else { render.line_obj_fetch_index },
        obj_fetch_ticket: if line_start { zero_selected_obj_ticket() } else { render.obj_fetch_ticket },
        obj_fetch_flags: if line_start { zero_obj_flags() } else { render.obj_fetch_flags },
        fetcher: render.fetcher,
        bg_fifo: render.bg_fifo,
        obj_fifo: if line_start { empty_obj_fifo() } else { render.obj_fifo },
        first_frame_blank: next_first_frame_blank(next_run),
    )
}

fn irq_edge(req: PpuIrqReq) -> PpuIrqEdge {
    match (req.vblank_req, req.stat_req) {
        (false, false) => PpuIrqEdge::None,
        (true, false) => PpuIrqEdge::VBlank,
        (false, true) => PpuIrqEdge::Stat,
        (true, true) => PpuIrqEdge::Both,
    }
}

fn recompute_lyc_match_flag(state: PpuState) -> bool {
    state.visible.ly == state.visible.regs.lyc
}

fn next_lyc_match_flag(
    prev_state: PpuState,
    candidate_state: PpuState,
    old_lcdc7: bool,
    requested_lcd_enable: bool,
    transition_taken: bool,
) -> bool {
    if transition_taken {
        if old_lcdc7 && !requested_lcd_enable {
            prev_state.status.lyc_match_flag
        } else if !old_lcdc7 && requested_lcd_enable {
            recompute_lyc_match_flag(candidate_state)
        } else {
            prev_state.status.lyc_match_flag
        }
    } else {
        match candidate_state.status.run {
            LcdRunState::Disabled => prev_state.status.lyc_match_flag,
            LcdRunState::WarmupBlankFrame =>
                match candidate_state.status.phase {
                    PpuPhase::LcdOff =>
                        if candidate_state.visible.ly != 0u8 {
                            false
                        } else {
                            recompute_lyc_match_flag(candidate_state)
                        },
                    _ => recompute_lyc_match_flag(candidate_state),
                },
            _ => recompute_lyc_match_flag(candidate_state),
        }
    }
}

fn lcd_reenable_lyc_rise_pulse(
    prev_state: PpuState,
    regs: PpuRegs,
    old_lcdc7: bool,
    requested_lcd_enable: bool,
    transition_taken: bool,
    next_lyc_match_flag: bool,
) -> bool {
    transition_taken
        && !old_lcdc7
        && requested_lcd_enable
        && regs.stat_sel.lyc_sel
        && !prev_state.status.lyc_match_flag
        && next_lyc_match_flag
}

fn lcd_reenable_lyc_level_hold(
    prev_state: PpuState,
    regs: PpuRegs,
    old_lcdc7: bool,
    requested_lcd_enable: bool,
    transition_taken: bool,
    next_lyc_match_flag: bool,
) -> bool {
    transition_taken
        && !old_lcdc7
        && requested_lcd_enable
        && regs.stat_sel.lyc_sel
        && prev_state.status.lyc_match_flag
        && next_lyc_match_flag
}

fn completed_line_summary(prev_state: PpuState, next_state: PpuState) -> Option<LineSummary> {
    match prev_state.status.phase {
        PpuPhase::Transfer$(x_out: _, discard_scx: _) => match next_state.status.phase {
            PpuPhase::HBlank$(dots_left: _) => Option::Some(basic_line_summary(prev_state, next_state)),
            _ => Option::None,
        },
        _ => Option::None,
    }
}

fn blank_reason(state: PpuState) -> BlankReason {
    match state.status.run {
        LcdRunState::Disabled => BlankReason::LcdDisabled,
        LcdRunState::WarmupBlankFrame => BlankReason::WarmupBlankFrame,
        LcdRunState::Running =>
            if state.visible.ly >= 144u8 {
                BlankReason::NonVisibleLine
            } else {
                BlankReason::NonVisibleDot
            },
    }
}

fn idle_mem_resp(resp: PpuMemResp) -> bool {
    match resp.result {
        PpuMemResult::Denied =>
            match resp.tag.region {
                MemRegion::Vram =>
                    match resp.tag.client {
                        MemClient::Cpu => resp.tag.id == 0u4,
                        _ => false,
                    },
                _ => false,
            },
        _ => false,
    }
}

fn mem_resp_valid(resp: PpuMemResp) -> bool {
    !idle_mem_resp(resp)
}

fn fetcher_mem_reqs(req_valid: bool, req: PpuMemReq) -> PpuMemReqs {
    if req_valid {
        PpuMemReqs$(count: 1u3, slots: [req, idle_ppu_mem_req(), idle_ppu_mem_req(), idle_ppu_mem_req()])
    } else {
        idle_ppu_mem_reqs()
    }
}

fn same_mem_region(left: MemRegion, right: MemRegion) -> bool {
    match left {
        MemRegion::Vram => match right {
            MemRegion::Vram => true,
            _ => false,
        },
        MemRegion::Oam => match right {
            MemRegion::Oam => true,
            _ => false,
        },
    }
}

fn same_mem_client(left: MemClient, right: MemClient) -> bool {
    match left {
        MemClient::Cpu => match right {
            MemClient::Cpu => true,
            _ => false,
        },
        MemClient::BgFetcher => match right {
            MemClient::BgFetcher => true,
            _ => false,
        },
        MemClient::ObjFetcher => match right {
            MemClient::ObjFetcher => true,
            _ => false,
        },
        MemClient::OamScanner => match right {
            MemClient::OamScanner => true,
            _ => false,
        },
        MemClient::Dma => match right {
            MemClient::Dma => true,
            _ => false,
        },
    }
}

fn same_mem_tag(left: MemTxnTag, right: MemTxnTag) -> bool {
    same_mem_region(left.region, right.region) && same_mem_client(left.client, right.client) && left.id == right.id
}

fn fetcher_source_is_object(render: PpuRenderState) -> bool {
    match render.fetcher.source {
        FetcherSource::Object => true,
        _ => false,
    }
}

fn obj_trigger_x(ticket: SelectedObjTicket) -> uint<8> {
    if ticket.x > 8u8 { trunc(ticket.x - 8u8) } else { 0u8 }
}

fn line_obj_ticket_at(line_objs: LineObjList, index: uint<4>) -> SelectedObjTicket {
    match index {
        0u4 => line_objs.slots[0],
        1u4 => line_objs.slots[1],
        2u4 => line_objs.slots[2],
        3u4 => line_objs.slots[3],
        4u4 => line_objs.slots[4],
        5u4 => line_objs.slots[5],
        6u4 => line_objs.slots[6],
        7u4 => line_objs.slots[7],
        8u4 => line_objs.slots[8],
        _ => line_objs.slots[9],
    }
}

fn has_pending_line_obj(render: PpuRenderState) -> bool {
    render.line_obj_fetch_index < render.line_objs.count
}

fn should_start_live_obj_fetch(render: PpuRenderState, regs: PpuRegs, x_out: uint<8>) -> bool {
    regs.lcdc.obj_enable
        && has_pending_line_obj(render)
        && !fetcher_source_is_object(render)
        && x_out >= obj_trigger_x(line_obj_ticket_at(render.line_objs, render.line_obj_fetch_index))
}

fn obj_fetch_with_req(render: PpuRenderState, step: FetcherStep, req: PpuMemReq) -> (PpuRenderState, PpuMemReqs) {
    let fetcher = render.fetcher;
    let next_fetcher = lib::ppu::sem::types::FetcherState$(
        epoch: fetcher.epoch,
        source: FetcherSource::Object,
        step: step,
        tile_id: fetcher.tile_id,
        tile_lo: fetcher.tile_lo,
        tile_hi: fetcher.tile_hi,
        map_x: fetcher.map_x,
        map_y: fetcher.map_y,
        row: fetcher.row,
        pending_push: fetcher.pending_push,
        pending_valid: true,
        pending_read: PendingRead$(tag: req.tag, epoch: fetcher.epoch),
    );
    (
        PpuRenderState$(
            dot_in_line: render.dot_in_line,
            x_out: render.x_out,
            window_state: render.window_state,
            window_line: render.window_line,
            oam_scan: render.oam_scan,
            line_objs: render.line_objs,
            line_obj_fetch_index: render.line_obj_fetch_index,
            obj_fetch_ticket: render.obj_fetch_ticket,
            obj_fetch_flags: render.obj_fetch_flags,
            fetcher: next_fetcher,
            bg_fifo: render.bg_fifo,
            obj_fifo: render.obj_fifo,
            first_frame_blank: render.first_frame_blank,
        ),
        fetcher_mem_reqs(true, req),
    )
}

fn start_live_obj_fetch(render: PpuRenderState) -> PpuRenderState {
    let fetcher = render.fetcher;
    PpuRenderState$(
        dot_in_line: render.dot_in_line,
        x_out: render.x_out,
        window_state: render.window_state,
        window_line: render.window_line,
        oam_scan: render.oam_scan,
        line_objs: render.line_objs,
        line_obj_fetch_index: render.line_obj_fetch_index,
        obj_fetch_ticket: line_obj_ticket_at(render.line_objs, render.line_obj_fetch_index),
        obj_fetch_flags: zero_obj_flags(),
        fetcher: lib::ppu::sem::types::FetcherState$(
            epoch: next_fetcher_epoch(fetcher.epoch),
            source: FetcherSource::Object,
            step: FetcherStep::GetTile,
            tile_id: 0u8,
            tile_lo: 0u8,
            tile_hi: 0u8,
            map_x: fetcher.map_x,
            map_y: fetcher.map_y,
            row: fetcher.row,
            pending_push: false,
            pending_valid: false,
            pending_read: fetcher.pending_read,
        ),
        bg_fifo: render.bg_fifo,
        obj_fifo: render.obj_fifo,
        first_frame_blank: render.first_frame_blank,
    )
}

fn resume_bg_fetcher(
    render: PpuRenderState,
    render_inputs: lib::ppu::sem::sample::PpuRenderInputs,
    visible_ly: uint<8>,
    x_out: uint<8>,
) -> lib::ppu::sem::types::FetcherState {
    start_bg_fetcher(render.fetcher, render_inputs, visible_ly, trunc(x_out >> 3))
}

fn matching_obj_resp(render: PpuRenderState, resp: PpuMemResp) -> bool {
    render.fetcher.pending_valid && same_mem_tag(render.fetcher.pending_read.tag, resp.tag)
}

fn ok_resp_data(resp: PpuMemResp) -> (bool, uint<8>) {
    match resp.result {
        PpuMemResult::Ok$(data) => (true, data),
        _ => (false, 0u8),
    }
}

fn complete_live_obj_fetch(
    render: PpuRenderState,
    render_inputs: lib::ppu::sem::sample::PpuRenderInputs,
    visible_ly: uint<8>,
    x_out: uint<8>,
) -> PpuRenderState {
    let meta = resolve_obj_meta(render.obj_fetch_ticket, render.fetcher.tile_id, render.obj_fetch_flags, visible_ly);
    let row = decode_obj_row(meta, render.fetcher.tile_lo, render.fetcher.tile_hi);
    let offset = obj_fifo_start_offset(render.obj_fetch_ticket, x_out);
    let left_clip = obj_fifo_left_clip(render.obj_fetch_ticket, x_out);
    PpuRenderState$(
        dot_in_line: render.dot_in_line,
        x_out: render.x_out,
        window_state: render.window_state,
        window_line: render.window_line,
        oam_scan: render.oam_scan,
        line_objs: render.line_objs,
        line_obj_fetch_index: trunc(render.line_obj_fetch_index + 1u4),
        obj_fetch_ticket: zero_selected_obj_ticket(),
        obj_fetch_flags: zero_obj_flags(),
        fetcher: resume_bg_fetcher(render, render_inputs, visible_ly, x_out),
        bg_fifo: render.bg_fifo,
        obj_fifo: obj_fifo_overlay_row_clipped(render.obj_fifo, row, offset, left_clip),
        first_frame_blank: render.first_frame_blank,
    )
}

fn advance_live_obj_fetch(
    render: PpuRenderState,
    render_inputs: lib::ppu::sem::sample::PpuRenderInputs,
    visible_ly: uint<8>,
    x_out: uint<8>,
    mem_resp: PpuMemResp,
) -> (PpuRenderState, PpuMemReqs) {
    if matching_obj_resp(render, mem_resp) {
        let (ok, data) = ok_resp_data(mem_resp);
        if !ok {
            (
                PpuRenderState$(
                    dot_in_line: render.dot_in_line,
                    x_out: render.x_out,
                    window_state: render.window_state,
                    window_line: render.window_line,
                    oam_scan: render.oam_scan,
                    line_objs: render.line_objs,
                    line_obj_fetch_index: render.line_obj_fetch_index,
                    obj_fetch_ticket: zero_selected_obj_ticket(),
                    obj_fetch_flags: zero_obj_flags(),
                    fetcher: resume_bg_fetcher(render, render_inputs, visible_ly, x_out),
                    bg_fifo: render.bg_fifo,
                    obj_fifo: render.obj_fifo,
                    first_frame_blank: render.first_frame_blank,
                ),
                idle_ppu_mem_reqs(),
            )
        } else {
            match render.fetcher.step {
                FetcherStep::GetTile => (
                    PpuRenderState$(
                        dot_in_line: render.dot_in_line,
                        x_out: render.x_out,
                        window_state: render.window_state,
                        window_line: render.window_line,
                        oam_scan: render.oam_scan,
                        line_objs: render.line_objs,
                        line_obj_fetch_index: render.line_obj_fetch_index,
                        obj_fetch_ticket: render.obj_fetch_ticket,
                        obj_fetch_flags: render.obj_fetch_flags,
                        fetcher: lib::ppu::sem::types::FetcherState$(
                            epoch: render.fetcher.epoch,
                            source: FetcherSource::Object,
                            step: FetcherStep::GetLo,
                            tile_id: data,
                            tile_lo: render.fetcher.tile_lo,
                            tile_hi: render.fetcher.tile_hi,
                            map_x: render.fetcher.map_x,
                            map_y: render.fetcher.map_y,
                            row: render.fetcher.row,
                            pending_push: false,
                            pending_valid: false,
                            pending_read: render.fetcher.pending_read,
                        ),
                        bg_fifo: render.bg_fifo,
                        obj_fifo: render.obj_fifo,
                        first_frame_blank: render.first_frame_blank,
                    ),
                    idle_ppu_mem_reqs(),
                ),
                FetcherStep::GetLo => (
                    PpuRenderState$(
                        dot_in_line: render.dot_in_line,
                        x_out: render.x_out,
                        window_state: render.window_state,
                        window_line: render.window_line,
                        oam_scan: render.oam_scan,
                        line_objs: render.line_objs,
                        line_obj_fetch_index: render.line_obj_fetch_index,
                        obj_fetch_ticket: render.obj_fetch_ticket,
                        obj_fetch_flags: decode_obj_flags(data),
                        fetcher: lib::ppu::sem::types::FetcherState$(
                            epoch: render.fetcher.epoch,
                            source: FetcherSource::Object,
                            step: FetcherStep::GetHi,
                            tile_id: render.fetcher.tile_id,
                            tile_lo: render.fetcher.tile_lo,
                            tile_hi: render.fetcher.tile_hi,
                            map_x: render.fetcher.map_x,
                            map_y: render.fetcher.map_y,
                            row: render.fetcher.row,
                            pending_push: false,
                            pending_valid: false,
                            pending_read: render.fetcher.pending_read,
                        ),
                        bg_fifo: render.bg_fifo,
                        obj_fifo: render.obj_fifo,
                        first_frame_blank: render.first_frame_blank,
                    ),
                    idle_ppu_mem_reqs(),
                ),
                FetcherStep::GetHi => (
                    PpuRenderState$(
                        dot_in_line: render.dot_in_line,
                        x_out: render.x_out,
                        window_state: render.window_state,
                        window_line: render.window_line,
                        oam_scan: render.oam_scan,
                        line_objs: render.line_objs,
                        line_obj_fetch_index: render.line_obj_fetch_index,
                        obj_fetch_ticket: render.obj_fetch_ticket,
                        obj_fetch_flags: render.obj_fetch_flags,
                        fetcher: lib::ppu::sem::types::FetcherState$(
                            epoch: render.fetcher.epoch,
                            source: FetcherSource::Object,
                            step: FetcherStep::Sleep,
                            tile_id: render.fetcher.tile_id,
                            tile_lo: data,
                            tile_hi: render.fetcher.tile_hi,
                            map_x: render.fetcher.map_x,
                            map_y: render.fetcher.map_y,
                            row: render.fetcher.row,
                            pending_push: false,
                            pending_valid: false,
                            pending_read: render.fetcher.pending_read,
                        ),
                        bg_fifo: render.bg_fifo,
                        obj_fifo: render.obj_fifo,
                        first_frame_blank: render.first_frame_blank,
                    ),
                    idle_ppu_mem_reqs(),
                ),
                FetcherStep::Sleep => (
                    PpuRenderState$(
                        dot_in_line: render.dot_in_line,
                        x_out: render.x_out,
                        window_state: render.window_state,
                        window_line: render.window_line,
                        oam_scan: render.oam_scan,
                        line_objs: render.line_objs,
                        line_obj_fetch_index: render.line_obj_fetch_index,
                        obj_fetch_ticket: render.obj_fetch_ticket,
                        obj_fetch_flags: render.obj_fetch_flags,
                        fetcher: lib::ppu::sem::types::FetcherState$(
                            epoch: render.fetcher.epoch,
                            source: FetcherSource::Object,
                            step: FetcherStep::Push,
                            tile_id: render.fetcher.tile_id,
                            tile_lo: render.fetcher.tile_lo,
                            tile_hi: data,
                            map_x: render.fetcher.map_x,
                            map_y: render.fetcher.map_y,
                            row: render.fetcher.row,
                            pending_push: true,
                            pending_valid: false,
                            pending_read: render.fetcher.pending_read,
                        ),
                        bg_fifo: render.bg_fifo,
                        obj_fifo: render.obj_fifo,
                        first_frame_blank: render.first_frame_blank,
                    ),
                    idle_ppu_mem_reqs(),
                ),
                FetcherStep::Push => (complete_live_obj_fetch(render, render_inputs, visible_ly, x_out), idle_ppu_mem_reqs()),
            }
        }
    } else if render.fetcher.pending_valid {
        (render, idle_ppu_mem_reqs())
    } else {
        match render.fetcher.step {
            FetcherStep::GetTile => obj_fetch_with_req(render, FetcherStep::GetTile, obj_fetch_tile_req(render.obj_fetch_ticket)),
            FetcherStep::GetLo => obj_fetch_with_req(render, FetcherStep::GetLo, obj_fetch_flags_req(render.obj_fetch_ticket)),
            FetcherStep::GetHi => {
                let meta = resolve_obj_meta(render.obj_fetch_ticket, render.fetcher.tile_id, render.obj_fetch_flags, visible_ly);
                obj_fetch_with_req(render, FetcherStep::GetHi, obj_fetch_lo_req(meta, render_inputs.lcdc_fetch.obj_size_8x16))
            },
            FetcherStep::Sleep => {
                let meta = resolve_obj_meta(render.obj_fetch_ticket, render.fetcher.tile_id, render.obj_fetch_flags, visible_ly);
                obj_fetch_with_req(render, FetcherStep::Sleep, obj_fetch_hi_req(meta, render_inputs.lcdc_fetch.obj_size_8x16))
            },
            FetcherStep::Push => (complete_live_obj_fetch(render, render_inputs, visible_ly, x_out), idle_ppu_mem_reqs()),
        }
    }
}

fn apply_live_transfer(
    state: PpuState,
    candidate_state: PpuState,
    mem_resp: PpuMemResp,
    frame_start: bool,
) -> (PpuState, PpuMemReqs, Option<ScanoutEvent>) {
    let was_transfer = match state.status.phase {
        PpuPhase::Transfer$(x_out: _, discard_scx: _) => true,
        _ => false,
    };
    let next_is_transfer = match candidate_state.status.phase {
        PpuPhase::Transfer$(x_out: _, discard_scx: _) => true,
        _ => false,
    };
    if !was_transfer && !next_is_transfer {
        (candidate_state, live_mem_reqs(state), Option::None)
    } else {
        let entering_transfer = !was_transfer && next_is_transfer;
        let next_discard_seed = match candidate_state.status.phase {
            PpuPhase::Transfer$(x_out: _, discard_scx: discard_scx) => discard_scx,
            _ => 0u3,
        };
        let base_x_out = if entering_transfer { 0u8 } else { state.render.x_out };
        let base_discard_scx = match state.status.phase {
            PpuPhase::Transfer$(x_out: _, discard_scx: discard_scx) => discard_scx,
            _ => next_discard_seed,
        };
        let render_inputs = sample_render_inputs(candidate_state.visible, candidate_state.sampled, candidate_state.status.phase);
        let obj_render =
            if next_is_transfer && should_start_live_obj_fetch(state.render, candidate_state.visible.regs, base_x_out) {
                start_live_obj_fetch(state.render)
            } else {
                state.render
            };
        if fetcher_source_is_object(obj_render) {
            let (next_obj_render, obj_mem_reqs) = advance_live_obj_fetch(
                obj_render,
                render_inputs,
                candidate_state.visible.ly,
                base_x_out,
                mem_resp,
            );
            let next_render =
                if next_is_transfer {
                    PpuRenderState$(
                        dot_in_line: candidate_state.render.dot_in_line,
                        x_out: base_x_out,
                        window_state: candidate_state.render.window_state,
                        window_line: candidate_state.render.window_line,
                        oam_scan: candidate_state.render.oam_scan,
                        line_objs: candidate_state.render.line_objs,
                        line_obj_fetch_index: next_obj_render.line_obj_fetch_index,
                        obj_fetch_ticket: next_obj_render.obj_fetch_ticket,
                        obj_fetch_flags: next_obj_render.obj_fetch_flags,
                        fetcher: next_obj_render.fetcher,
                        bg_fifo: next_obj_render.bg_fifo,
                        obj_fifo: next_obj_render.obj_fifo,
                        first_frame_blank: candidate_state.render.first_frame_blank,
                    )
                } else {
                    PpuRenderState$(
                        dot_in_line: candidate_state.render.dot_in_line,
                        x_out: 0u8,
                        window_state: candidate_state.render.window_state,
                        window_line: candidate_state.render.window_line,
                        oam_scan: candidate_state.render.oam_scan,
                        line_objs: candidate_state.render.line_objs,
                        line_obj_fetch_index: 0u4,
                        obj_fetch_ticket: zero_selected_obj_ticket(),
                        obj_fetch_flags: zero_obj_flags(),
                        fetcher: initial_bg_fetcher_state(),
                        bg_fifo: clear_bg_fifo(),
                        obj_fifo: empty_obj_fifo(),
                        first_frame_blank: candidate_state.render.first_frame_blank,
                    )
                };
            (
                PpuState$(
                    visible: candidate_state.visible,
                    status: candidate_state.status,
                    sampled: candidate_state.sampled,
                    render: next_render,
                ),
                obj_mem_reqs,
                Option::None,
            )
        } else {
        let base_fetcher =
            if entering_transfer {
                start_bg_fetcher(state.render.fetcher, render_inputs, candidate_state.visible.ly, 0u5)
            } else {
                state.render.fetcher
            };
        let base_bg_fifo = if entering_transfer { clear_bg_fifo() } else { state.render.bg_fifo };
        let fetcher_output = advance_bg_fetcher(
            base_fetcher,
            render_inputs,
            candidate_state.visible.ly,
            trunc(base_x_out >> 3),
            state.render.window_line,
            bg_fifo_has_room_for_row(base_bg_fifo),
            mem_resp_valid(mem_resp),
            mem_resp,
            false,
            false,
            false,
            false,
        );
        let pipe_output = advance_bg_pipe(
            base_bg_fifo,
            state.render.window_state,
            state.render.window_line,
            candidate_state.sampled,
            render_inputs,
            base_x_out,
            frame_start,
            false,
            base_discard_scx,
            fetcher_output.push_valid,
            fetcher_output.push_row,
            render_inputs.bgp_pop,
        );
        let next_window_state =
            if fetcher_output.push_valid {
                note_window_tile_push(pipe_output.next_window_state)
            } else {
                pipe_output.next_window_state
            };
        let obj_popped =
            if pipe_output.pixel_valid {
                pop_obj_fifo(state.render.obj_fifo)
            } else {
                ObjFifoPopResult$(next_fifo: state.render.obj_fifo, pixel_valid: false, pixel: lib::ppu::sem::types::zero_obj_pixel())
            };
        let next_x_out =
            if pipe_output.pixel_valid {
                trunc(base_x_out + 1u8)
            } else {
                base_x_out
            };
        let pixel_scanout = lib::ppu::rtl::mixer::emit_mixed_scanout(
            pipe_output.pixel_valid && !candidate_state.render.first_frame_blank && candidate_state.visible.ly < 144u8,
            pipe_output.pixel,
            obj_popped.pixel_valid,
            obj_popped.pixel,
            render_inputs,
            base_x_out,
            candidate_state.visible.ly,
        );
        let next_status = PpuStatusState$(
            run: candidate_state.status.run,
            phase:
                if next_is_transfer {
                    PpuPhase::Transfer$(x_out: next_x_out, discard_scx: pipe_output.next_discard_scx)
                } else {
                    candidate_state.status.phase
                },
            stat_irq: candidate_state.status.stat_irq,
            lyc_match_flag: candidate_state.status.lyc_match_flag,
        );
        (
            PpuState$(
                visible: candidate_state.visible,
                status: next_status,
                sampled: candidate_state.sampled,
                render: PpuRenderState$(
                    dot_in_line: candidate_state.render.dot_in_line,
                    x_out: if next_is_transfer { next_x_out } else { 0u8 },
                    window_state: next_window_state,
                    window_line: pipe_output.next_window_line,
                    oam_scan: candidate_state.render.oam_scan,
                    line_objs: candidate_state.render.line_objs,
                    line_obj_fetch_index: candidate_state.render.line_obj_fetch_index,
                    obj_fetch_ticket: if next_is_transfer { candidate_state.render.obj_fetch_ticket } else { zero_selected_obj_ticket() },
                    obj_fetch_flags: if next_is_transfer { candidate_state.render.obj_fetch_flags } else { zero_obj_flags() },
                    fetcher: if next_is_transfer { fetcher_output.next_state } else { initial_bg_fetcher_state() },
                    bg_fifo: if next_is_transfer { pipe_output.next_fifo } else { clear_bg_fifo() },
                    obj_fifo: if next_is_transfer { obj_popped.next_fifo } else { empty_obj_fifo() },
                    first_frame_blank: candidate_state.render.first_frame_blank,
                ),
            ),
            fetcher_mem_reqs(fetcher_output.req_valid, fetcher_output.req),
            pixel_scanout,
        )
        }
    }
}

fn live_scanout_event(
    next_state: PpuState,
    line_start: bool,
    frame_start: bool,
    pixel_scanout: Option<ScanoutEvent>,
) -> Option<ScanoutEvent> {
    if frame_start {
        Option::Some(ScanoutEvent::FrameStart)
    } else if line_start {
        Option::Some(ScanoutEvent::LineStart$(y: next_state.visible.ly))
    } else {
        match pixel_scanout {
            Option::Some(event) => Option::Some(event),
            Option::None => Option::Some(blank_scanout_event(next_state.visible.ly, blank_reason(next_state))),
        }
    }
}

fn live_mem_reqs(state: PpuState) -> PpuMemReqs {
    match state.status.phase {
        PpuPhase::OamScan$(index: _, found: _) =>
            if oam_pair_advance_dot(state.render.dot_in_line) {
                idle_ppu_mem_reqs()
            } else {
                live_oam_scan_req(state.render.oam_scan)
            },
        _ => idle_ppu_mem_reqs(),
    }
}

pub fn step_dot(state: PpuState, input: DotInput) -> DotOutput {
    let (written_regs, stat_write_seen, force_enable, force_disable) = fold_events(input, state.visible.regs);
    let stored_lcd_enable =
        if force_disable {
            false
        } else if force_enable {
            true
        } else {
            written_regs.lcdc.lcd_enable
        };
    // LCDC storage updates immediately, but execution-time LCD power transitions
    // are driven by explicit ForceLcdPower events so callers can model delayed
    // enable effects separately from readback timing.
    let requested_lcd_enable =
        if force_disable {
            false
        } else if force_enable {
            true
        } else {
            state.visible.regs.lcdc.lcd_enable
        };
    let next_regs = set_lcd_enable(written_regs, stored_lcd_enable);
    let state_with_regs = PpuState$(
        visible: PpuVisibleState$(regs: next_regs, ly: state.visible.ly),
        status: state.status,
        sampled: state.sampled,
        render: state.render,
    );
    let old_lcdc7 = state.visible.regs.lcdc.lcd_enable;
    let transition_taken = old_lcdc7 != requested_lcd_enable;
    let transition_state = handle_lcd_transition(state_with_regs, old_lcdc7, requested_lcd_enable);
    let (candidate_state, line_start, frame_start) =
        if transition_taken {
            (transition_state, false, false)
        } else {
            let (next_phase, next_ly, next_sampled, line_start, frame_start) = advance_timing(state_with_regs, input, next_regs);
            let next_run = advance_run_state(state.status.run, frame_start);
            let next_visible = PpuVisibleState$(regs: next_regs, ly: next_ly);
            (
                PpuState$(
                    visible: next_visible,
                    status: PpuStatusState$(
                        run: next_run,
                        phase: next_phase,
                        stat_irq: state.status.stat_irq,
                        lyc_match_flag: state.status.lyc_match_flag,
                    ),
                    sampled: next_sampled,
                    render: update_render_state(
                        state.render,
                        state.status.phase,
                        state.visible.ly,
                        next_regs,
                        next_run,
                        next_phase,
                        line_start,
                    ),
                ),
                line_start,
                frame_start,
            )
        };
    let candidate_lyc_match_flag =
        next_lyc_match_flag(state, candidate_state, old_lcdc7, requested_lcd_enable, transition_taken);
    let candidate_status = PpuStatusState$(
        run: candidate_state.status.run,
        phase: candidate_state.status.phase,
        stat_irq: candidate_state.status.stat_irq,
        lyc_match_flag: candidate_lyc_match_flag,
    );
    let candidate_state = PpuState$(
        visible: candidate_state.visible,
        status: candidate_status,
        sampled: candidate_state.sampled,
        render: candidate_state.render,
    );
    let (next_stat_irq, next_irq_req) = irq_req(
        state.status,
        candidate_state.status,
        candidate_state.visible.regs,
        candidate_state.visible.ly,
        stat_write_seen,
        dmg_behavior_config().features,
    );
    let next_irq_req = PpuIrqReq$(
        vblank_req: next_irq_req.vblank_req,
        stat_req:
            (
                next_irq_req.stat_req
                && !lcd_reenable_lyc_level_hold(
                    state,
                    candidate_state.visible.regs,
                    old_lcdc7,
                    requested_lcd_enable,
                    transition_taken,
                    candidate_state.status.lyc_match_flag,
                )
            )
            || lcd_reenable_lyc_rise_pulse(
                state,
                candidate_state.visible.regs,
                old_lcdc7,
                requested_lcd_enable,
                transition_taken,
                candidate_state.status.lyc_match_flag,
            ),
    );
    let final_status = PpuStatusState$(
        run: candidate_state.status.run,
        phase: candidate_state.status.phase,
        stat_irq: next_stat_irq,
        lyc_match_flag: candidate_state.status.lyc_match_flag,
    );
    let final_state = PpuState$(
        visible: candidate_state.visible,
        status: final_status,
        sampled: candidate_state.sampled,
        render: candidate_state.render,
    );
    let (final_state, mem_reqs, pixel_scanout) = apply_live_transfer(state, final_state, input.mem_resp, frame_start);
    let line_summary = completed_line_summary(state, final_state);
    let scanout = live_scanout_event(final_state, line_start, frame_start, pixel_scanout);
    let semantic = PpuSemanticCommit$(
        ly_after: final_state.visible.ly,
        mode_after: visible_mode(final_state.status),
        stat_line_after: final_state.status.stat_irq.line_high,
        irq_edge: irq_edge(next_irq_req),
        scanout: scanout,
    );

    DotOutput$(
        next_state: final_state,
        mem_reqs: mem_reqs,
        mmio_resp: idle_ppu_mmio_resp(),
        irq_req: next_irq_req,
        scanout: scanout,
        semantic: Option::Some(semantic),
        line_summary: line_summary,
    )
}
