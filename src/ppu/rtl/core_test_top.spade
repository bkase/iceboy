use std::option::Option;

use lib::ppu::rtl::core::ppu_core;
use lib::ppu::sem::events::mmio::{MmioReg, MmioWrite};
use lib::ppu::sem::events::{idle_oam_dma_state, zero_video_coord};
use lib::ppu::sem::memory::idle_ppu_mem_resp;
use lib::sim::ppu_support::{encode_lcd_run, encode_ppu_mode, encode_ppu_phase, timed_events_from_direct};

fn decode_mmio_reg(target_i: uint<4>) -> MmioReg {
    match target_i {
        1u4 => MmioReg::Stat,
        2u4 => MmioReg::Scy,
        3u4 => MmioReg::Scx,
        4u4 => MmioReg::Lyc,
        5u4 => MmioReg::Wy,
        6u4 => MmioReg::Wx,
        7u4 => MmioReg::Bgp,
        8u4 => MmioReg::Obp0,
        9u4 => MmioReg::Obp1,
        _ => MmioReg::Lcdc,
    }
}

pub entity core_test_top(
    clk_i: clock,
    rst_i: bool,
    dot_ce_i: bool,
    write_valid_i: bool,
    write_target_i: uint<4>,
    write_value_i: uint<8>,
) -> uint<41> {
    let write =
        if write_valid_i {
            Option::Some(MmioWrite$(target: decode_mmio_reg(write_target_i), value: write_value_i))
        } else {
            Option::None
        };
    let (bus_events, bus_event_count) = timed_events_from_direct(zero_video_coord(), 0u64, write, Option::None);
    let core = inst ppu_core(
        clk_i,
        rst_i,
        dot_ce_i,
        zero_video_coord(),
        bus_events,
        bus_event_count,
        idle_ppu_mem_resp(),
        idle_oam_dma_state(),
    );
    let trace = core.trace;

    zext(encode_ppu_phase(trace.phase_after))
        | (zext(trace.ly_after) << 3)
        | (zext(trace.dot_in_line_after) << 11)
        | (zext(encode_ppu_mode(trace.mode_after)) << 20)
        | (zext(lib::util::bit(trace.stat_line_after)) << 23)
        | (zext(lib::util::bit(core.irq_req.vblank_req)) << 24)
        | (zext(lib::util::bit(core.irq_req.stat_req)) << 25)
        | (zext(encode_lcd_run(trace.run_after)) << 26)
        | (zext(lib::util::bit(trace.first_frame_blank_after)) << 28)
        | (zext(trace.stat_readback_after) << 29)
        | (zext(core.mem_reqs.count) << 37)
        | (zext(match core.scanout {
            std::option::Option::Some(event) => {
                let _ = event;
                1u1
            },
            std::option::Option::None => 0u1,
        }) << 40)
}
