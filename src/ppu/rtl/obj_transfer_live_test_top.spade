use std::option::Option;

use lib::bus::ppu_event_bridge::ppu_event_bridge;
use lib::bus::types::BusReq;
use lib::ppu::sem::events::mmio::{MmioReg, MmioWrite};
use lib::ppu::sem::events::{DotInput, idle_oam_dma_state, zero_video_coord};
use lib::ppu::sem::memory::{MemClient, MemRegion, PpuMemKind, PpuMemReq, PpuMemResp, PpuMemResult, idle_ppu_mem_req, idle_ppu_mem_resp};
use lib::ppu::sem::step::step_dot;
use lib::ppu::sem::types::{
    FetcherSource,
    FetcherStep,
    LcdRunState,
    LineObjList,
    PpuPhase,
    PpuRegs,
    PpuSamplingState,
    PpuState,
    PpuStatusState,
    PpuVisibleState,
    SelectedObjTicket,
    StatIrqState,
    empty_bg_fifo,
    empty_obj_fifo,
    empty_oam_scan_state,
    initial_fetcher_state,
};
use lib::sim::encode::{encode_scanout_kind, scanout_shade, scanout_source, scanout_x};
use lib::sim::ppu_support::{build_test_lcdc, held_dot_output, ppu_debug_trace, timed_events_from_direct};

fn configured_ticket(oam_index: uint<6>, x: uint<8>, y: uint<8>, selection_rank: uint<4>) -> SelectedObjTicket {
    SelectedObjTicket$(oam_index: oam_index, x: x, y: y, selection_rank: selection_rank)
}

fn configured_line_objs(line_obj_count_i: uint<4>, ticket0_x_i: uint<8>, ticket1_x_i: uint<8>, ticket2_x_i: uint<8>, ticket_y_i: uint<8>) -> LineObjList {
    LineObjList$(
        count: line_obj_count_i,
        slots: [
            configured_ticket(0u6, ticket0_x_i, ticket_y_i, 0u4),
            configured_ticket(1u6, ticket1_x_i, ticket_y_i, 1u4),
            configured_ticket(2u6, ticket2_x_i, ticket_y_i, 2u4),
            configured_ticket(3u6, trunc(ticket2_x_i + 8u8), ticket_y_i, 3u4),
            configured_ticket(4u6, trunc(ticket2_x_i + 16u8), ticket_y_i, 4u4),
            configured_ticket(5u6, trunc(ticket2_x_i + 24u8), ticket_y_i, 5u4),
            configured_ticket(6u6, trunc(ticket2_x_i + 32u8), ticket_y_i, 6u4),
            configured_ticket(7u6, trunc(ticket2_x_i + 40u8), ticket_y_i, 7u4),
            configured_ticket(8u6, trunc(ticket2_x_i + 48u8), ticket_y_i, 8u4),
            configured_ticket(9u6, trunc(ticket2_x_i + 56u8), ticket_y_i, 9u4),
        ],
    )
}

fn seeded_regs(obj_size_8x16_i: bool, obj_enable_i: bool) -> PpuRegs {
    PpuRegs$(
        lcdc: build_test_lcdc(false, false, true, false, obj_size_8x16_i, obj_enable_i, true),
        stat_sel: lib::ppu::sem::types::zero_stat_select(),
        scy: 0u8,
        scx: 0u8,
        lyc: 0u8,
        wy: 0u8,
        wx: 0u8,
        bgp: 0xfcu8,
        obp0: 0xe4u8,
        obp1: 0xe4u8,
    )
}

fn decode_fetcher_source(source_i: uint<2>) -> FetcherSource {
    match source_i {
        1u2 => FetcherSource::Window,
        2u2 => FetcherSource::Object,
        _ => FetcherSource::Background,
    }
}

fn decode_fetcher_step(step_i: uint<3>) -> FetcherStep {
    match step_i {
        1u3 => FetcherStep::GetLo,
        2u3 => FetcherStep::GetHi,
        3u3 => FetcherStep::Sleep,
        4u3 => FetcherStep::Push,
        _ => FetcherStep::GetTile,
    }
}

fn seeded_fetcher(seed_fetcher_valid_i: bool, seed_fetcher_source_i: uint<2>, seed_fetcher_step_i: uint<3>) -> lib::ppu::sem::types::FetcherState {
    if seed_fetcher_valid_i {
        lib::ppu::sem::types::FetcherState$(
            epoch: 0u4,
            source: decode_fetcher_source(seed_fetcher_source_i),
            step: decode_fetcher_step(seed_fetcher_step_i),
            tile_id: 0u8,
            tile_lo: 0u8,
            tile_hi: 0u8,
            map_x: 0u5,
            map_y: 0u5,
            row: 0u3,
            pending_push: false,
            pending_valid: false,
            pending_read: initial_fetcher_state().pending_read,
        )
    } else {
        initial_fetcher_state()
    }
}

fn seeded_state(
    line_obj_count_i: uint<4>,
    ticket0_x_i: uint<8>,
    ticket1_x_i: uint<8>,
    ticket2_x_i: uint<8>,
    ticket_y_i: uint<8>,
    visible_ly_i: uint<8>,
    obj_size_8x16_i: bool,
    obj_enable_i: bool,
    start_x_out_i: uint<8>,
    start_dot_in_line_i: uint<9>,
    seed_fetcher_valid_i: bool,
    seed_fetcher_source_i: uint<2>,
    seed_fetcher_step_i: uint<3>,
    start_in_oam_scan_i: bool,
) -> PpuState {
    let seeded_fetcher_state = seeded_fetcher(seed_fetcher_valid_i, seed_fetcher_source_i, seed_fetcher_step_i);
    PpuState$(
        visible: PpuVisibleState$(regs: seeded_regs(obj_size_8x16_i, obj_enable_i), ly: visible_ly_i),
        status: PpuStatusState$(
            run: LcdRunState::Running,
            phase:
                if start_in_oam_scan_i {
                    PpuPhase::OamScan$(index: 40u6, found: line_obj_count_i)
                } else {
                    PpuPhase::Transfer$(x_out: start_x_out_i, discard_scx: 0u3)
                },
            stat_irq: StatIrqState$(line_high: false),
            lyc_match_flag: true,
        ),
        sampled: PpuSamplingState$(
            scx_low3_line: 0u3,
            wy_triggered_this_frame: false,
            window_enable_at_mode2_start: false,
        ),
        render: lib::ppu::sem::types::PpuRenderState$(
            dot_in_line: start_dot_in_line_i,
            x_out: start_x_out_i,
            window_state: lib::ppu::sem::types::WindowState::Inactive,
            window_line: 0u8,
            oam_scan: empty_oam_scan_state(),
            line_objs: configured_line_objs(line_obj_count_i, ticket0_x_i, ticket1_x_i, ticket2_x_i, ticket_y_i),
            line_obj_fetch_index: 0u4,
            line_obj_fetched_mask: 0u10,
            obj_fetch_ticket: lib::ppu::sem::types::zero_selected_obj_ticket(),
            obj_fetch_flags: lib::ppu::sem::types::zero_obj_flags(),
            bg_fetcher_resume: initial_fetcher_state(),
            fetcher: seeded_fetcher_state,
            bg_fifo: empty_bg_fifo(),
            obj_fifo: empty_obj_fifo(),
            first_frame_blank: false,
        ),
    )
}

fn encode_fetcher_source(source: FetcherSource) -> uint<2> {
    match source {
        FetcherSource::Background => 0u2,
        FetcherSource::Window => 1u2,
        FetcherSource::Object => 2u2,
    }
}

fn encode_fetcher_step(step: FetcherStep) -> uint<3> {
    match step {
        FetcherStep::GetTile => 0u3,
        FetcherStep::GetLo => 1u3,
        FetcherStep::GetHi => 2u3,
        FetcherStep::Sleep => 3u3,
        FetcherStep::Push => 4u3,
    }
}

fn encode_mem_region(region: MemRegion) -> uint<1> {
    match region {
        MemRegion::Vram => 0u1,
        MemRegion::Oam => 1u1,
    }
}

fn encode_mem_client(client: MemClient) -> uint<3> {
    match client {
        MemClient::Cpu => 0u3,
        MemClient::BgFetcher => 1u3,
        MemClient::ObjFetcher => 2u3,
        MemClient::OamScanner => 3u3,
        MemClient::Dma => 4u3,
    }
}

fn decode_mmio_reg(target_i: uint<4>) -> MmioReg {
    match target_i {
        1u4 => MmioReg::Stat,
        2u4 => MmioReg::Scy,
        3u4 => MmioReg::Scx,
        4u4 => MmioReg::Lyc,
        5u4 => MmioReg::Wy,
        6u4 => MmioReg::Wx,
        7u4 => MmioReg::Bgp,
        8u4 => MmioReg::Obp0,
        9u4 => MmioReg::Obp1,
        _ => MmioReg::Lcdc,
    }
}

fn decode_bus_req(kind_i: uint<2>, addr_i: uint<16>, data_i: uint<8>) -> BusReq {
    match kind_i {
        1u2 => BusReq::Read$(addr: addr_i),
        2u2 => BusReq::Write$(addr: addr_i, data: data_i),
        _ => BusReq::Idle,
    }
}

fn phase_x_out(phase: PpuPhase) -> uint<8> {
    match phase {
        PpuPhase::Transfer$(x_out, discard_scx: _) => x_out,
        _ => 0u8,
    }
}

fn response_data(req: PpuMemReq) -> uint<8> {
    match req.tag.region {
        MemRegion::Oam =>
            match req.tag.id {
                0u4 => 0x24u8,
                1u4 => 0x00u8,
                _ => 0u8,
            },
        MemRegion::Vram =>
            match req.tag.id {
                2u4 => 0x50u8,
                3u4 => 0x30u8,
                _ => 0u8,
            },
    }
}

fn response_data_configured(req: PpuMemReq, tile_id_i: uint<8>, flags_i: uint<8>, tile_lo_i: uint<8>, tile_hi_i: uint<8>) -> uint<8> {
    match req.tag.region {
        MemRegion::Oam =>
            match req.addr {
                0xfe02u16 => tile_id_i,
                0xfe03u16 => flags_i,
                0xfe06u16 => 0x02u8,
                0xfe07u16 => 0x00u8,
                0xfe0au16 => 0x03u8,
                0xfe0bu16 => 0x00u8,
                0xfe0eu16 => 0x03u8,
                0xfe0fu16 => 0x00u8,
                0xfe12u16 => 0x03u8,
                0xfe13u16 => 0x00u8,
                0xfe16u16 => 0x03u8,
                0xfe17u16 => 0x00u8,
                0xfe1au16 => 0x03u8,
                0xfe1bu16 => 0x00u8,
                0xfe1eu16 => 0x03u8,
                0xfe1fu16 => 0x00u8,
                0xfe22u16 => 0x03u8,
                0xfe23u16 => 0x00u8,
                0xfe26u16 => 0x03u8,
                0xfe27u16 => 0x00u8,
                _ => 0u8,
            },
        MemRegion::Vram =>
            match req.addr {
                0x8010u16 => tile_lo_i,
                0x8011u16 => tile_hi_i,
                0x8020u16 => 0x03u8,
                0x8021u16 => 0x00u8,
                0x8030u16 => tile_lo_i,
                0x8031u16 => tile_hi_i,
                _ => 0u8,
            },
    }
}

fn ok_mem_resp(req: PpuMemReq, tile_id_i: uint<8>, flags_i: uint<8>, tile_lo_i: uint<8>, tile_hi_i: uint<8>) -> PpuMemResp {
    let result = match req.kind {
        PpuMemKind::Read => PpuMemResult::Ok$(data: response_data_configured(req, tile_id_i, flags_i, tile_lo_i, tile_hi_i)),
        PpuMemKind::Write$(data: data) => PpuMemResult::Ok$(data: data),
    };
    PpuMemResp$(tag: req.tag, result: result)
}

pub entity obj_transfer_live_test_top(
    clk_i: clock,
    rst_i: bool,
    dot_ce_i: bool,
    line_obj_count_i: uint<4>,
    ticket0_x_i: uint<8>,
    ticket1_x_i: uint<8>,
    ticket2_x_i: uint<8>,
    ticket_y_i: uint<8>,
    visible_ly_i: uint<8>,
    obj_size_8x16_i: bool,
    obj_enable_i: bool,
    start_x_out_i: uint<8>,
    start_dot_in_line_i: uint<9>,
    seed_fetcher_valid_i: bool,
    seed_fetcher_source_i: uint<2>,
    seed_fetcher_step_i: uint<3>,
    tile_id_i: uint<8>,
    flags_i: uint<8>,
    tile_lo_i: uint<8>,
    tile_hi_i: uint<8>,
    write_valid_i: bool,
    write_target_i: uint<4>,
    write_value_i: uint<8>,
    use_bridge_i: bool,
    m_ce_i: bool,
    req_kind_i: uint<2>,
    req_addr_i: uint<16>,
    req_data_i: uint<8>,
    start_in_oam_scan_i: bool,
) -> uint<111> {
    decl state_reg;
    decl pending_req_reg;
    decl pending_resp_valid_reg;
    let mem_resp_now = if pending_resp_valid_reg { ok_mem_resp(pending_req_reg, tile_id_i, flags_i, tile_lo_i, tile_hi_i) } else { idle_ppu_mem_resp() };
    let write =
        if write_valid_i {
            Option::Some(MmioWrite$(target: decode_mmio_reg(write_target_i), value: write_value_i))
        } else {
            Option::None
        };
    let state_now = PpuState$(
        visible: PpuVisibleState$(
            regs: state_reg.visible.regs,
            ly: state_reg.visible.ly,
        ),
        status: state_reg.status,
        sampled: state_reg.sampled,
        render: state_reg.render,
    );
    let (direct_events, direct_event_count) = timed_events_from_direct(zero_video_coord(), 0u64, write, Option::None);
    let (bridge_events, bridge_event_count) = inst ppu_event_bridge(
        clk_i,
        rst_i,
        m_ce_i,
        decode_bus_req(req_kind_i, req_addr_i, req_data_i),
        state_now.render.dot_in_line == 0u9 && state_now.visible.ly == 0u8,
        state_now.visible.ly,
        state_now.render.dot_in_line,
    );
    let (bus_events, bus_event_count) =
        if use_bridge_i {
            (bridge_events, bridge_event_count)
        } else {
            (direct_events, direct_event_count)
        };
    let step = step_dot(
        state_now,
        DotInput$(bus_events: bus_events, bus_event_count: bus_event_count, mem_resp: mem_resp_now, dma_state: idle_oam_dma_state()),
    );
    let visible = held_dot_output(state_now, dot_ce_i, step);
    let trace = ppu_debug_trace(zero_video_coord(), visible);
    let next_pending_req = if visible.mem_reqs.count != 0u3 { visible.mem_reqs.slots[0] } else { idle_ppu_mem_req() };
    let scanout_valid = match visible.scanout {
        std::option::Option::Some(_) => true,
        std::option::Option::None => false,
    };
    let scanout_kind = match visible.scanout {
        std::option::Option::Some(event) => encode_scanout_kind(event),
        std::option::Option::None => 0u2,
    };
    let scanout_source_value = match visible.scanout {
        std::option::Option::Some(event) => scanout_source(event),
        std::option::Option::None => 0u2,
    };
    let scanout_x_value = match visible.scanout {
        std::option::Option::Some(event) => scanout_x(event),
        std::option::Option::None => 0u8,
    };
    let scanout_shade_value = match visible.scanout {
        std::option::Option::Some(event) => scanout_shade(event),
        std::option::Option::None => 0u2,
    };

    reg(clk_i) state_reg: PpuState reset(rst_i: seeded_state(
        line_obj_count_i,
        ticket0_x_i,
        ticket1_x_i,
        ticket2_x_i,
        ticket_y_i,
        visible_ly_i,
        obj_size_8x16_i,
        obj_enable_i,
        start_x_out_i,
        start_dot_in_line_i,
        seed_fetcher_valid_i,
        seed_fetcher_source_i,
        seed_fetcher_step_i,
        start_in_oam_scan_i,
    )) =
        if dot_ce_i { visible.next_state } else { state_reg };
    reg(clk_i) pending_req_reg: PpuMemReq reset(rst_i: idle_ppu_mem_req()) =
        if dot_ce_i { next_pending_req } else { pending_req_reg };
    reg(clk_i) pending_resp_valid_reg: bool reset(rst_i: false) =
        if dot_ce_i { visible.mem_reqs.count != 0u3 } else { pending_resp_valid_reg };

    zext(encode_fetcher_source(trace.fetcher.source))
        | (zext(encode_fetcher_step(trace.fetcher.step)) << 2)
        | (zext(visible.mem_reqs.count) << 5)
        | (zext(trace.obj_fifo.count) << 8)
        | (zext(next_pending_req.addr) << 13)
        | (zext(encode_mem_region(next_pending_req.tag.region)) << 29)
        | (zext(encode_mem_client(next_pending_req.tag.client)) << 30)
        | (zext(next_pending_req.tag.id) << 33)
        | (zext(lib::util::bit(pending_resp_valid_reg)) << 37)
        | (zext(trace.line_objs.count) << 38)
        | (zext(visible.next_state.render.line_obj_fetch_index) << 42)
        | (zext(visible.next_state.render.x_out) << 46)
        | (zext(trace.ly_after) << 54)
        | (zext(trace.dot_in_line_after) << 62)
        | (zext(lib::sim::ppu_support::encode_ppu_phase(trace.phase_after)) << 71)
        | (zext(lib::util::bit(scanout_valid)) << 74)
        | (zext(scanout_kind) << 75)
        | (zext(scanout_source_value) << 77)
        | (zext(scanout_x_value) << 79)
        | (zext(scanout_shade_value) << 87)
        | (zext(phase_x_out(trace.phase_after)) << 89)
        | (zext(visible.next_state.render.obj_fetch_ticket.oam_index) << 97)
        | (zext(visible.next_state.render.obj_fetch_ticket.x) << 103)
}
