use std::option::Option;

use lib::ppu::rtl::mixer::{bg_pixel_enabled, emit_mixed_scanout, mix_bg_obj_pixel, mix_bg_pixel, palette_lookup};
use lib::ppu::sem::sample::PpuRenderInputs;
use lib::ppu::sem::scanout::{PixelSource, ScanoutEvent};
use lib::ppu::sem::types::{BgPixel, ObjDrawRank, ObjPaletteSel, ObjPixel};
use lib::sim::encode::encode_pixel_source;
use lib::sim::ppu_support::build_test_lcdc;

fn build_render(
    bgp_pop_i: uint<8>,
    obp0_pop_i: uint<8>,
    obp1_pop_i: uint<8>,
    bg_enable_i: bool,
    obj_enable_i: bool,
) -> PpuRenderInputs {
    PpuRenderInputs$(
        lcdc_fetch: build_test_lcdc(false, false, true, false, false, obj_enable_i, bg_enable_i),
        scx_fetch: 0u8,
        scy_fetch: 0u8,
        scx_low3_line: 0u3,
        wx_live: 0u8,
        wy_triggered_this_frame: false,
        bgp_pop: bgp_pop_i,
        obp0_pop: obp0_pop_i,
        obp1_pop: obp1_pop_i,
        lyc_eq_live: false,
    )
}

fn decode_palette_sel(palette_sel_i: bool) -> ObjPaletteSel {
    if palette_sel_i { ObjPaletteSel::Obp1 } else { ObjPaletteSel::Obp0 }
}

pub entity mixer_test_top(
    bg_color_idx_i: uint<2>,
    bg_from_window_i: bool,
    bgp_pop_i: uint<8>,
    obp0_pop_i: uint<8>,
    obp1_pop_i: uint<8>,
    bg_enable_i: bool,
    obj_enable_i: bool,
    pixel_valid_i: bool,
    obj_valid_i: bool,
    obj_color_i: uint<2>,
    obj_palette_sel_i: bool,
    obj_bg_over_obj_i: bool,
    obj_x_i: uint<8>,
    obj_selection_rank_i: uint<4>,
    x_i: uint<8>,
    y_i: uint<8>,
) -> uint<32> {
    let bg_pixel = BgPixel$(shade: bg_color_idx_i, palette: 0u8, from_window: bg_from_window_i);
    let obj_pixel = ObjPixel$(
        color: obj_color_i,
        palette: decode_palette_sel(obj_palette_sel_i),
        draw_rank: ObjDrawRank$(x: obj_x_i, selection_rank: obj_selection_rank_i),
        bg_over_obj: obj_bg_over_obj_i,
    );
    let render = build_render(bgp_pop_i, obp0_pop_i, obp1_pop_i, bg_enable_i, obj_enable_i);
    let _ = mix_bg_pixel(bg_pixel, render, x_i, y_i);
    let mixed = mix_bg_obj_pixel(bg_pixel, obj_valid_i, obj_pixel, render, x_i, y_i);
    let event = emit_mixed_scanout(pixel_valid_i, bg_pixel, obj_valid_i, obj_pixel, render, x_i, y_i);

    zext(palette_lookup(bg_color_idx_i, bgp_pop_i))
        | (zext(lib::util::bit(bg_pixel_enabled(render.lcdc_fetch))) << 2)
        | (zext(mixed.shade) << 3)
        | (zext(mixed.x) << 5)
        | (zext(mixed.y) << 13)
        | (zext(encode_pixel_source(mixed.source)) << 21)
        | (zext(match event {
            Option::Some(scanout) => match scanout {
                ScanoutEvent::Pixel$(emit) => lib::util::bit(emit.shade == mixed.shade),
                _ => 0u1,
            },
            Option::None => 0u1,
        }) << 23)
        | (zext(lib::util::bit(match event { Option::Some(_) => true, Option::None => false })) << 24)
        | (zext(obj_color_i) << 25)
        | (zext(lib::util::bit(bg_from_window_i)) << 27)
        | (zext(lib::util::bit(obj_bg_over_obj_i)) << 28)
        | (zext(lib::util::bit(obj_valid_i)) << 29)
        | (zext(lib::util::bit(obj_enable_i)) << 30)
}
